rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // This rule allows any authenticated user to read and write to any part
    // of your database. This is great for getting started with development,
    // but you should create more restrictive rules before launching your app
    // to protect your data.
    //
    // For example, you might want to ensure users can only edit their own
    // family's documents.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
