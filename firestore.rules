rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin(clubId) {
      return request.auth != null && request.auth.token.email in get(/databases/$(database)/documents/clubs/$(clubId)).data.admins;
    }

    match /clubs/{clubId} {
      // Anyone can read club configs to load the page
      allow read: if true;
      allow write: if isAdmin(clubId);
    }
    
    match /locations/{locationId} {
      // Anyone authenticated can view locations
      allow read: if request.auth != null;
      // Only admins of the club can modify locations
      allow write: if isAdmin(resource.data.clubId) || isAdmin(request.resource.data.clubId);
    }

    match /families/{familyId} {
      allow read, write: if request.auth != null;
    }
    
    match /checkins/{checkinId} {
      allow read, write: if request.auth != null;
    }
  }
}
